{
  "name": "ai-instruct",
  "version": "2.0.3",
  "description": "Practical markdown guides for developers building websites with AI coding assistants",
  "bin": {
    "ai-instruct": "bin/init.js"
  },
  "scripts": {
    "build:skills": "node scripts/build-skills.js",
    "sync:versions": "node scripts/sync-versions.js",
    "version": "node scripts/sync-versions.js && node scripts/build-skills.js && git add .claude-plugin/ skills/",
    "prepublishOnly": "node scripts/build-skills.js"
  },
  "keywords": [
    "ai",
    "llm",
    "claude",
    "cursor",
    "copilot",
    "windsurf",
    "guides",
    "instructions"
  ],
  "files": [
    "bin/",
    "scripts/",
    "skills/",
    ".claude-plugin/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "*-guide.md",
    "llms.txt"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziniman/ai-instruct.git"
  },
  "engines": {
    "node": ">=18"
  }
}
